{
  "$schema": "https://schemas.wp.org/wp/6.2/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "defaultDuotone": false,
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "duotone": [],
      "gradients": [],
      "link": false,
      "palette": [
        {
          "name": "Black",
          "slug": "black",
          "color": "#000"
        },
        {
          "name": "Dark",
          "slug": "dark",
          "color": "#211d1e"
        },
        {
          "name": "Dark Grey",
          "slug": "dark-grey",
          "color": "#4a4a4a"
        },
        {
          "name": "Grey",
          "slug": "grey",
          "color": "#7f7f7f"
        },
        {
          "name": "Grey Light",
          "slug": "grey-light",
          "color": "#fbfbfb"
        },
        {
          "name": "White",
          "slug": "white",
          "color": "#fff"
        },
        {
          "name": "Green",
          "slug": "green",
          "color": "#00e8cc"
        },
        {
          "name": "Purple",
          "slug": "purple",
          "color": "#ab71ff"
        },
        {
          "name": "Orange",
          "slug": "orange",
          "color": "#fb3"
        }
      ]
    },
    "custom": {
      "typography": {
        "fontFamily": "Futura PT, Arial"
      },
      "layout": {
        "contentSize": "1420px"
      },
      "font-size": {
        "mobile": {
          "heading1": "52px",
          "heading2": "48px",
          "heading3": "44px",
          "heading4": "38px",
          "heading5": "24px",
          "heading6": "20px",
          "bodySmall": "12px",
          "bodyMedium": "14px",
          "bodyLarge": "16px"
        },
        "desktop": {
          "heading1": "96px",
          "heading2": "82px",
          "heading3": "60px",
          "heading4": "50px",
          "heading5": "40px",
          "heading6": "34px",
          "bodySmall": "16px",
          "bodyMedium": "18px",
          "bodyLarge": "20px"
        }
      }
    },
    "layout": {
      "contentSize": "var(--wp--custom--layout--content-size)"
    },
    "spacing": {
      "blockGap": true,
      "margin": true,
      "padding": true,
      "units": ["rem", "%", "vw", "vh"]
    },
    "typography": {
      "customFontSize": false,
      "lineHeight": false,
      "dropCap": false,
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "var(--wp--custom--font-size--desktop--body-small)"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "var(--wp--custom--font-size--desktop--body-medium)"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "var(--wp--custom--font-size--desktop--body-large)"
        }
      ]
    },
    "blocks": {
      "core/columns": {
        "spacing": {
          "blockGap": true
        }
      },
      "core/button": {
        "color": {
          "palette": []
        }
      }
    }
  },
  "styles": {
    "color": {},
    "elements": {
      "h1": {},
      "h2": {},
      "h3": {},
      "h4": {},
      "h5": {},
      "h6": {},
      "link": {}
    },
    "typography": {},
    "blocks": {}
  }
}
