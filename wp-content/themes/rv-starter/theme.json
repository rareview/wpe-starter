      "palette": [
        {
          "name": "Black",
          "slug": "black",
          "color": "#000"
        },
        {
          "name": "Dark",
          "slug": "dark",
          "color": "#211d1e"
        },
        {
          "name": "Dark Grey",
          "slug": "dark-grey",
          "color": "#4a4a4a"
        },
        {
          "name": "Grey",
          "slug": "grey",
          "color": "#7f7f7f"
        },
        {
          "name": "Grey Light",
          "slug": "grey-light",
          "color": "#fbfbfb"
        },
        {
          "name": "White",
          "slug": "white",
          "color": "#fff"
        },
        {
          "name": "Green",
          "slug": "green",
          "color": "#00e8cc"
        },
        {
          "name": "Purple",
          "slug": "purple",
          "color": "#ab71ff"
        },
        {
          "name": "Orange",
          "slug": "orange",
          "color": "#fb3"
        }
      ]
    },
    "custom": {
      "typography": {
        "fontFamily": "Futura PT, Arial"
      },
      "layout": {
        "contentSize": "1420px"
      },
      "spacing": {
