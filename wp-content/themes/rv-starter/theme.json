    "layout": {
      "contentSize": "var(--wp--custom--layout--content-size)"
    },
    "spacing": {
      "blockGap": true,
      "margin": true,
      "padding": true,
      "units": ["rem"]
    },
    "typography": {
      "customFontSize": false,
      "lineHeight": false,
      "dropCap": false,
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.778rem"
        },
        {
          "name": "Normal",
          "slug": "normal",
          "size": "1rem"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.111rem"
        }
      ]
    },
    "blocks": {
      "core/columns": {
        "spacing": {
          "blockGap": true
        }
      },
      "core/button": {
        "color": {
          "palette": []
        }
      }
    }
  },
  "styles": {
    "color": {},
    "elements": {
      "h1": {},
