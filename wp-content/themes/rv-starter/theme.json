{
  "$schema": "https://schemas.wp.org/wp/6.2/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "defaultDuotone": false,
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "duotone": [],
      "gradients": [],
      "link": false,
      "palette": [
        {
          "name": "Black",
          "slug": "black",
          "color": "#000"
        },
        {
          "name": "Dark",
          "slug": "dark",
          "color": "#211d1e"
        },
        {
          "name": "Dark Grey",
          "slug": "dark-grey",
          "color": "#4a4a4a"
        },
        {
          "name": "Grey",
          "slug": "grey",
          "color": "#7f7f7f"
        },
        {
          "name": "Grey Light",
          "slug": "grey-light",
          "color": "#fbfbfb"
        },
        {
          "name": "White",
          "slug": "white",
          "color": "#fff"
        },
        {
          "name": "Green",
          "slug": "green",
          "color": "#00e8cc"
        },
        {
          "name": "Purple",
          "slug": "purple",
          "color": "#ab71ff"
        },
        {
          "name": "Orange",
          "slug": "orange",
          "color": "#fb3"
        }
      ]
    },
    "custom": {
      "layout": {
        "contentSize": "1420px"
      },
      "spacing": {
        "20": "0.25rem",
        "30": "0.5rem",
        "40": "1rem",
        "50": "1.5rem",
        "60": "2rem",
        "70": "3rem",
        "80": "4rem"
      },
      "font-size": {
        "mobile": {
          "heading1": "52px",
          "heading2": "48px",
          "heading3": "44px",
          "heading4": "38px",
          "heading5": "24px",
          "heading6": "16px",
          "bodySmall": "12px",
          "bodyMedium": "14px",
          "bodyLarge": "16px"
        },
        "desktop": {
          "heading1": "96px",
          "heading2": "82px",
          "heading3": "60px",
          "heading4": "50px",
          "heading5": "40px",
          "heading6": "24px",
          "bodySmall": "16px",
          "bodyMedium": "18px",
          "bodyLarge": "20px"
        }
      }
    },
    "layout": {
      "contentSize": "var(--wp--custom--layout--content-size)"
    },
    "spacing": {
      "blockGap": true,
      "margin": true,
      "padding": true,
      "units": ["rem", "%", "vw", "vh"],
      "spacingSizes": [
        {
          "size": "var(--wp--custom--spacing--20)",
          "slug": "20",
          "name": "XS"
        },
        {
          "size": "var(--wp--custom--spacing--30)",
          "slug": "30",
          "name": "SM"
        },
        {
          "size": "var(--wp--custom--spacing--40)",
          "slug": "40",
          "name": "MD"
        },
        {
          "size": "var(--wp--custom--spacing--50)",
          "slug": "50",
          "name": "LG"
        },
        {
          "size": "var(--wp--custom--spacing--60)",
          "slug": "60",
          "name": "XL"
        },
        {
          "size": "var(--wp--custom--spacing--70)",
          "slug": "70",
          "name": "2XL"
        },
        {
          "size": "var(--wp--custom--spacing--80)",
          "slug": "80",
          "name": "3XL"
        }
      ]
    },
    "typography": {
      "customFontSize": false,
      "lineHeight": false,
      "dropCap": false,
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "var(--wp--custom--font-size--desktop--body-small)"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "var(--wp--custom--font-size--desktop--body-medium)"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "var(--wp--custom--font-size--desktop--body-large)"
        }
      ],
      "fontFamilies": [
        {
          "name": "Futura PT",
          "slug": "futura-pt",
          "fontFamily": "Futura PT, Arial, sans-serif",
          "fontFace": [
            {
              "fontFamily": "Futura PT",
              "fontWeight": "400",
              "fontStyle": "normal",
              "src": ["file:./assets/fonts/futura-pt/FuturaPT-Book.woff2"]
            },
            {
              "fontFamily": "Futura PT",
              "fontWeight": "700",
              "fontStyle": "normal",
              "src": ["file:./assets/fonts/futura-pt/FuturaPT-Bold.woff2"]
            },
            {
              "fontFamily": "Futura PT",
              "fontWeight": "800",
              "fontStyle": "normal",
              "src": ["file:./assets/fonts/futura-pt/FuturaPT-ExtraBold.woff2"]
            }
          ]
        },
        {
          "name": "Instrument Serif",
          "slug": "instrument-serif",
          "fontFamily": "Instrument Serif, serif",
          "fontFace": [
            {
              "fontFamily": "Instrument Serif",
              "fontWeight": "400",
              "fontStyle": "normal",
              "src": [
                "file:./assets/fonts/instrument-serif/InstrumentSerif-Regular.woff2"
              ]
            }
          ]
        }
      ]
    },
    "blocks": {
      "core/columns": {
        "spacing": {
          "blockGap": true
        }
      },
      "core/button": {
        "color": {
          "palette": []
        }
      }
    }
  },
  "styles": {
    "color": {},
    "elements": {
      "h1": {},
      "h2": {},
      "h3": {},
      "h4": {},
      "h5": {},
      "h6": {},
      "link": {}
    },
    "typography": {},
    "blocks": {}
  }
}
